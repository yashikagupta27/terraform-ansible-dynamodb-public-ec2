{
  "commands": [
    "#!/bin/bash",
    "set -e",

    "dnf install -y wget tar",

    "cd /tmp",
    "wget https://fastdl.mongodb.org/linux/mongodb-linux-x86_64-amazon2023-6.0.14.tgz",

    "tar -xzf mongodb-linux-x86_64-amazon2023-6.0.14.tgz",

    "cp mongodb-linux-x86_64-amazon2023-6.0.14/bin/* /usr/local/bin/",

    "mkdir -p /data/db",
    "chown -R root:root /data/db",

    "mongod --version"
  ]
}
